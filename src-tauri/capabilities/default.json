{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    "notification:default",
    "dialog:default",
    "clipboard-manager:allow-read-text"
  ]
}
