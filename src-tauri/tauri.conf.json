{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GrabIt",
  "version": "0.1.0",
  "identifier": "com.wyasyn.grabit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GrabIt",
        "width": 940,
        "height": 680,
        "minWidth": 700,
        "minHeight": 520,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Download videos from YouTube, X, Instagram, Facebook and 1800+ sites",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
